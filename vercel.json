{
  "builds": [
    {
      "src": "website/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "website/dist" }
    }
  ],
  "routes": [
    { "src": "/about", "dest": "/website/dist/index.html" },
    { "src": "/home", "dest": "/website/dist/index.html" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/website/dist/index.html" }
  ]
}